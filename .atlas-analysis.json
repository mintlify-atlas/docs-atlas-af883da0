  "keyFeatures": [
    "Static-first architecture with no build pipeline",
    "Privacy-focused on-device headline generation",
    "One-click copy and social sharing",
    "Mock front page export to PNG",
    "Session persistence with localStorage",
    "Browser agent interface for automation",
    "Keyboard navigation support",
    "Filter and search capabilities"
  ],
  "publicApiSurface": [
    "window.Neckass.agent.call('get_state')",
    "window.Neckass.agent.call('shuffle')",
    "window.Neckass.agent.call('previous')",
    "window.Neckass.agent.call('generate')",
    "window.Neckass.agent.call('set_filters', params)",
    "window.Neckass.agent.call('clear_filters')",
    "window.Neckass.agent.call('select_headline', index)",
    "window.Neckass.agent.call('list_headlines')"
  ]
